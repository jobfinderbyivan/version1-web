# ===== Job Search Automation System — configuration =====
# Copy this file to ".env" and fill in what you have. Everything is optional
# except ADMIN_EMAIL — the app runs in demo/outbox mode without the rest.

# The first admin account. Created automatically on first launch.
ADMIN_EMAIL=ivandoublejr@gmail.com

# Where alert emails (token budget, deliverability) are sent.
ALERT_EMAIL=ivandoublejr@gmail.com

# --- AI (Anthropic Claude) ---
# Without a key the app falls back to keyword-based heuristics for parsing,
# matching and advice (clearly lower quality, but everything still works).
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8

# --- Email ---
# EMAIL_MODE: "auto" (resend if RESEND_API_KEY, else smtp if creds, else outbox),
#             or force "resend" / "smtp" / "outbox".
# In outbox mode every email is written to data/outbox/*.html so you can read
# OTP codes and job emails locally without any email account.
EMAIL_MODE=auto
# Resend HTTP email API (https://resend.com) — REQUIRED on hosts that block SMTP
# (Railway/Render/Fly). Free tier ~3,000/mo. Verify your domain for production.
RESEND_API_KEY=
# Sender for the Resend API. Default onboarding@resend.dev works immediately but
# only delivers to your Resend account email; verify your domain to email anyone.
EMAIL_FROM=JobFinder <onboarding@resend.dev>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
# Use a Gmail App Password (Google Account -> Security -> 2-Step Verification -> App passwords)
SMTP_PASSWORD=
SMTP_FROM_NAME=Job Search Assistant
# Sender address — leave empty to use SMTP_USER (correct for Gmail).
# For relays like Brevo/SendGrid set this to your verified sender email.
SMTP_FROM=

# --- Job search providers ---
# If neither is configured, a built-in demo provider generates realistic sample
# listings so the whole pipeline can be tested end to end.
# Adzuna (free key: https://developer.adzuna.com/)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us
# JSearch via RapidAPI (https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch)
JSEARCH_API_KEY=
# TheirStack (https://theirstack.com) — often returns direct company ATS links;
# note: bills API credits per job returned
THEIRSTACK_API_KEY=
# USAJOBS.gov developer API (https://developer.usajobs.gov) — US federal jobs,
# free. USAJOBS_USER_AGENT must be the email you registered with.
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=

# --- Commute time calculation (optional) ---
GOOGLE_MAPS_API_KEY=

# --- Search dorking (optional, for tools/google_dork_ats.py) ---
# Recommended: Serper.dev — sign up free at https://serper.dev (Google sign-in,
# 2,500 free queries, no credit card), copy the API key from the dashboard.
SERPER_API_KEY=
# Legacy fallback: Google CSE (closed to NEW customers since 2026 — only works
# if you already had access).
GOOGLE_CSE_KEY=
GOOGLE_CSE_ID=

# --- Server ---
HOST=127.0.0.1
PORT=8000
# Base URL used inside emails for dashboard links and tracking pixels
APP_BASE_URL=http://127.0.0.1:8000
SECRET_KEY=change-me-to-a-long-random-string

# --- Scheduler (24h clock, local time) ---
# The main automation runs daily at this hour; each user is processed only when
# their own cadence (daily / every 3 days / weekly) is due.
AUTOMATION_HOUR=8
SCHEDULER_ENABLED=true
